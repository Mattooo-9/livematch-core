# ===== App =====
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-prod
ADMIN_API_TOKEN=change-me-admin-token

# ===== Telegram =====
BOT_TOKEN=123456:your-telegram-bot-token-from-botfather
BOT_WEBHOOK_SECRET=change-me-webhook-secret
BOT_WEBHOOK_URL=https://yourdomain.com
BOT_USE_WEBHOOK=false
ADMIN_TG_IDS=123456789

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://livematch:livematch@db:5432/livematch

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== Payments =====
TELEGRAM_PAYMENTS_PROVIDER_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
FONDY_MERCHANT_ID=
FONDY_SECRET_KEY=
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_SECRET_KEY=

# ===== AI module (optional but recommended) =====
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# ===== Web app =====
WEBAPP_BASE_URL=http://localhost:8080/app
API_BASE_URL=http://localhost:8000

# ===== Business limits (defaults shown) =====
FREE_LIKES_PER_DAY=15
INCOMING_LIKES_SOFT_LIMIT=20
INCOMING_LIMIT_WINDOW_HOURS=24
ACTIVE_CHAT_TTL_HOURS=24
CHAT_INACTIVITY_AUTOCLOSE_HOURS=12
MAX_CHAT_EXTENSIONS=10
MESSAGES_PER_MINUTE_LIMIT=20
IDENTICAL_MESSAGE_LIMIT=3
REFERRAL_INVITER_BONUS_LIKES=5
REFERRAL_INVITED_BONUS_LIKES=5
DEFAULT_SEARCH_RADIUS_KM=15
RUN_SCHEDULER_IN_API=true
