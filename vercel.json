{
  "version": 2,
  "name": "livematch-core-backup",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {"maxLambdaSize": "50mb"}
    }
  ],
  "routes": [
    {"src": "/(.*)", "dest": "api/index.py"}
  ],
  "env": {
    "BOT_USE_WEBHOOK": "true",
    "NODE_ROLE": "secondary",
    "PYTHONUNBUFFERED": "1",
    "WATCHDOG_MAX_MEM_MB": "256"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}
